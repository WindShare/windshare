  "asciiMatrix": {
    "first": 32,
    "last": 126,
    "path": {
      "skip": "?#",
      "alphanumeric": true,
      "literal": "-._~$&+,/:;=@"
    },
    "query": {
      "skip": "#",
      "alphanumeric": true,
      "literal": "-._~!$&()*+,;=:@/?"
    },
    "userinfo": {
      "skip": "/?#",
      "alphanumeric": true,
      "literal": "-._~",
      "escaped": {
        ":": "%3A",
        "@": "%40"
      }
    }
  }
