{
  "version": 1,
  "kind": "geometry",
  "description": "打包流资源几何的跨实现契约:所有大小与计数均为十进制字符串。chunkSize 必须是 [1 KiB,4 MiB] 内的 2 次幂;chunkCount = ceil(streamBytes/chunkSize),最多 2^26;一位/块的稠密状态最多 8 MiB;streamBytes 最多 2^48(256 TiB)。segmentBytes=16 GiB 是独立的加密子密钥轮换跨度,绝不放宽 4 MiB 块/缓冲上限。实现必须先验证资源边界,再分配块状态。expected 是 valid 或稳定的错误类别。",
  "cases": [
    {
      "name": "protocol-constants",
      "constants": {
        "minChunkSize": "1024",
        "maxChunkSize": "4194304",
        "maxChunkCount": "67108864",
        "maxChunkStateBytes": "8388608",
        "maxStreamBytes": "281474976710656",
        "segmentBytes": "17179869184"
      }
    },
    {
      "name": "empty-stream",
      "chunkSize": "1024",
      "streamBytes": "0",
      "expected": "valid",
      "chunkCount": "0"
    },
    {
      "name": "one-byte-stream",
      "chunkSize": "1024",
      "streamBytes": "1",
      "expected": "valid",
      "chunkCount": "1"
    },
    {
      "name": "exact-minimum-chunk",
      "chunkSize": "1024",
      "streamBytes": "1024",
      "expected": "valid",
      "chunkCount": "1"
    },
    {
      "name": "minimum-chunk-plus-one",
      "chunkSize": "1024",
      "streamBytes": "1025",
      "expected": "valid",
      "chunkCount": "2"
    },
    {
      "name": "exact-maximum-chunk-count",
      "chunkSize": "1024",
      "streamBytes": "68719476736",
      "expected": "valid",
      "chunkCount": "67108864"
    },
    {
      "name": "maximum-stream",
      "chunkSize": "4194304",
      "streamBytes": "281474976710656",
      "expected": "valid",
      "chunkCount": "67108864"
    },
    {
      "name": "chunk-size-below-minimum",
      "chunkSize": "512",
      "streamBytes": "0",
      "expected": "chunk-size-too-small"
    },
    {
      "name": "chunk-size-above-maximum",
      "chunkSize": "8388608",
      "streamBytes": "0",
      "expected": "chunk-size-too-large"
    },
    {
      "name": "chunk-size-not-power-of-two",
      "chunkSize": "1536",
      "streamBytes": "0",
      "expected": "chunk-size-not-power-of-two"
    },
    {
      "name": "negative-stream",
      "chunkSize": "1024",
      "streamBytes": "-1",
      "expected": "negative-stream"
    },
    {
      "name": "one-over-maximum-chunk-count",
      "chunkSize": "1024",
      "streamBytes": "68719476737",
      "expected": "too-many-chunks"
    },
    {
      "name": "one-over-maximum-stream",
      "chunkSize": "4194304",
      "streamBytes": "281474976710657",
      "expected": "stream-too-large"
    }
  ]
}
